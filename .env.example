# Flutter does not auto-load .env files.
# Pass these values at build/run time with --dart-define flags (see README).
#
# Example:
#   flutter run --dart-define=API_ENCRYPTED_URL=$API_ENCRYPTED_URL
#
# On Windows (PowerShell):
#   flutter run --dart-define=API_ENCRYPTED_URL=https://your-backend-host.example.com

# Copy this file to .env and fill in your own backend URLs.
# Never commit the real .env file -- it is already in .gitignore.

API_ENCRYPTED_URL=https://your-backend-host.example.com
API_UNENCRYPTED_URL=http://your-local-ip:7000
